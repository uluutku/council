# Edge Function secrets for the ai-chat function (server-only; never VITE_*).
# Copy to supabase/functions/.env and fill in for real-provider local testing.
#
# AI_PROVIDER_MODE selects the provider:
#   openrouter -> calls the real OpenRouter gateway (requires OPENROUTER_API_KEY)
#   mock       -> deterministic local responses (local/loopback Supabase only)
AI_PROVIDER_MODE=openrouter

# Required when AI_PROVIDER_MODE=openrouter. Get a key at https://openrouter.ai.
# Keep this only here or in deployed Supabase secrets — never in source or VITE_*.
OPENROUTER_API_KEY=

# The text model id.
OPENROUTER_TEXT_MODEL=deepseek/deepseek-v4-flash

# The image-analysis model id.
OPENROUTER_VISION_MODEL=google/gemini-2.5-flash

# OpenRouter file-parser engine used for text-based PDFs. OCR fallback is not enabled.
OPENROUTER_PDF_ENGINE=cloudflare-ai

# Optional OpenRouter attribution. Leave blank rather than inventing a production URL.
OPENROUTER_APP_URL=
OPENROUTER_APP_NAME=

# Application-controlled provider deadlines.
AI_TEXT_TIMEOUT_MS=90000
AI_VISION_TIMEOUT_MS=45000
AI_PDF_TIMEOUT_MS=60000

# Explicit browser origins for fail-closed CORS. Local mock development may use these values.
APP_ORIGINS=http://127.0.0.1:4173,http://localhost:4173
# Optional single-origin compatibility setting. Prefer APP_ORIGINS for multiple origins.
APP_ORIGIN=
AI_EXPOSE_RUNTIME_METADATA=false
