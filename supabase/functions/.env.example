# Edge Function secrets for the ai-chat function (server-only; never VITE_*).
# Copy to supabase/functions/.env and fill in for real-provider local testing.
#
# AI_PROVIDER_MODE selects the provider:
#   openrouter -> calls the real OpenRouter gateway (requires OPENROUTER_API_KEY)
#   mock       -> deterministic local responses (local/loopback Supabase only)
AI_PROVIDER_MODE=openrouter

# Required when AI_PROVIDER_MODE=openrouter. Get a key at https://openrouter.ai.
# Keep this only here or in deployed Supabase secrets — never in source or VITE_*.
OPENROUTER_API_KEY=

# The text model id.
OPENROUTER_TEXT_MODEL=deepseek/deepseek-v4-flash
