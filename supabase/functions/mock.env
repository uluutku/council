# Deterministic local provider for automated tests and offline development.
# Contains no secrets. Mock mode refuses to run against a remote Supabase project.
AI_PROVIDER_MODE=mock
OPENROUTER_TEXT_MODEL=mock/council-assistant
OPENROUTER_VISION_MODEL=mock/council-vision
OPENROUTER_PDF_ENGINE=mock/cloudflare-ai
AI_TEXT_TIMEOUT_MS=250
AI_VISION_TIMEOUT_MS=250
AI_PDF_TIMEOUT_MS=250
AI_EXPOSE_RUNTIME_METADATA=true
